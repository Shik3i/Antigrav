# 🐨 KoalaWeb – Environment Variables Configuration Example
# Copy this file to '.env' and adjust the values as needed for your environment.

# 🌐 Server Configuration
PORT=3001
NODE_ENV=development

# 🔑 Authentication Security
# Generate a robust secret key (e.g. using openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here

# 📡 Optional Integrations (e.g., Twitch, external APIs)
# TWITCH_CLIENT_ID=your_twitch_client_id
# TWITCH_CLIENT_SECRET=your_twitch_client_secret

# 🐨 First-Start Superadmin Configuration (used when database is empty)
SUPERADMIN_USERNAME=admin_koala
SUPERADMIN_PASSWORD=koala
SUPERADMIN_DISPLAY_NAME=Admin Koala
SUPERADMIN_STARTING_COINS=133700

# 🔐 Admin Panel Access Code (for unlocking admin interface)
# This is separate from the database superadmin credentials
ADMIN_PASSWORD=Entangled-Napping7-Custodian
