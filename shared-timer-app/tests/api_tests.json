{
    "baseUrl": "http://localhost:3001",
    "tests": [
        {
            "name": "Room Creation (Public)",
            "endpoint": "/api/rooms",
            "method": "POST",
            "body": {
                "name": "Test Room Public",
                "isPublic": true,
                "defaultRole": "read",
                "defaultDurationMinutes": 25
            },
            "expectedStatus": 200,
            "validate": [
                "success",
                "readToken",
                "writeToken"
            ]
        },
        {
            "name": "Room Creation (Private)",
            "endpoint": "/api/rooms",
            "method": "POST",
            "body": {
                "name": "Test Room Private",
                "isPublic": false,
                "defaultRole": "read",
                "defaultDurationMinutes": 10
            },
            "expectedStatus": 200,
            "validate": [
                "success",
                "readToken",
                "writeToken"
            ]
        },
        {
            "name": "Get Public Rooms",
            "endpoint": "/api/rooms",
            "method": "GET",
            "expectedStatus": 200,
            "validateType": "array"
        },
        {
            "name": "Get Highscores",
            "endpoint": "/api/highscores",
            "method": "GET",
            "expectedStatus": 200,
            "validate": [
                "topUsers",
                "stats"
            ]
        },
        {
            "name": "Action API Security (404 check)",
            "endpoint": "/api/test/rooms/invalid-id-999/action",
            "method": "POST",
            "body": {
                "action": "START"
            },
            "expectedStatus": 404
        }
    ]
}