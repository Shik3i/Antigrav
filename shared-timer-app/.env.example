# 🐨 KoalaWeb – Environment Variables Configuration Example
# Copy this file to '.env' and adjust the values as needed for your environment.

# 🌐 Server Configuration
PORT=3001
NODE_ENV=development

# 🔑 Authentication Security
# Generate a robust secret key (e.g. using openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here

# 📡 Optional Integrations (e.g., Twitch, external APIs)
# TWITCH_CLIENT_ID=your_twitch_client_id
# TWITCH_CLIENT_SECRET=your_twitch_client_secret
