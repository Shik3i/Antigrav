{
  "manifest_version": 3,
  "name": "SyncExtension",
  "version": "2.8.2",
  "description": "Minimal Media-Sync for HTML5 videos.",
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://timer.shik3i.net/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Media Sync",
    "default_icon": {
      "16": "icons/icon128.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://timer.shik3i.net/*",
        "http://localhost:3001/*"
      ],
      "js": [
        "bridge.js"
      ]
    }
  ]
}
